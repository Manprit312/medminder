PORT=3847
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Local dev: SQLite file (default). Production: set DATABASE_URL to use PostgreSQL (e.g. Neon).
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_PATH=./data/medminder.db
# CORS is configured in src/index.ts (all origins allowed for mobile + web).

# Public URL where users open the app (password-reset + caretaker invite links). One URL only, no trailing slash.
# Do NOT paste a comma-separated list here (use CORS_ORIGINS or similar elsewhere for multiple origins).
# Example production: https://medminder-zhjh.onrender.com
APP_PUBLIC_URL=http://localhost:8100

# --- Email (pick one) ---
#
# Option A — Resend (recommended): https://resend.com — create an API key, verify your domain, then:
# Mail is sent via Resend's HTTPS API (port 443). On PaaS (e.g. Render), direct SMTP often times out — do not rely on smtp.resend.com from the server.
RESEND_API_KEY=
#
# From address must be a domain you verified in Resend (or use onboarding@resend.dev only for quick tests).
EMAIL_FROM="MedMinder" <noreply@yourdomain.com>
#
# Option B — Generic SMTP (SendGrid, Mailgun, etc.):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
#
# Leave all unset for local dev: reset links / caretaker links are printed to server logs (and optional DEV_EXPOSE_RESET_URL).

# Set to true to return devResetUrl in the forgot-password JSON response (local testing only).
DEV_EXPOSE_RESET_URL=false

# Behind a reverse proxy (nginx, Railway, Render): set so rate limits use real client IPs.
TRUST_PROXY=0

# Simulated Plus/Free tier (POST /api/billing/simulate-tier). Disabled when NODE_ENV=production unless set.
DEV_BILLING_SIMULATION=false
# Or allow simulation on a hosted staging server without NODE_ENV=development:
# MEDMINDER_ALLOW_BILLING_SIMULATION=true
