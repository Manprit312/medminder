PORT=3847
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Local dev: SQLite file (default). Production: set DATABASE_URL to use PostgreSQL (e.g. Neon).
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_PATH=./data/medminder.db
# CORS is configured in src/index.ts (all origins allowed for mobile + web).

# Public URL of the Ionic web app (used in password-reset emails). No trailing slash.
# Example production: https://app.yourdomain.com
APP_PUBLIC_URL=http://localhost:8100

# SMTP — required for password reset emails in production.
# Leave unset for local dev: reset links are printed to server logs (and optional DEV_EXPOSE_RESET_URL).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MedMinder" <noreply@example.com>

# Set to true to return devResetUrl in the forgot-password JSON response (local testing only).
DEV_EXPOSE_RESET_URL=false

# Behind a reverse proxy (nginx, Railway, Render): set so rate limits use real client IPs.
TRUST_PROXY=0
